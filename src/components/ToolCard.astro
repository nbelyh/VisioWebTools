---
const { href, imageSrc, title, body } = Astro.props;
---

<div class="tool-card not-prose">
  <!-- Image on the left -->
  <img src={imageSrc} alt="Image" class="tool-card-image">

  <!-- Content on the right -->
  <div class="tool-card-content">
      <h2 class="font-bold text-xl mb-4">{title}</h2>
      <p class="text-gray-600 mb-4">{body}</p>
      <div class="flex justify-end">
        <!-- Button -->
        <a href={href} class="btn-primary">Open</a>
      </div>
  </div>
</div>
